rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'longl7622@gmail.com' && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Profile ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) && 
             data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt is number &&
             data.get('name', '') is string && data.get('name', '').size() <= 128 &&
             data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 512 &&
             data.get('role', 'user') is string && data.get('role', 'user') in ['user', 'admin'];
    }

    match /users/{userId} {
      allow read: if true; // Public profiles (or can restrict to isSignedIn())
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidUser(incoming()) && incoming().createdAt == request.time.toMillis() && incoming().get('role', 'user') == (isAdmin() ? 'admin' : 'user');
      allow update: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming()) && incoming().uid == existing().uid && incoming().createdAt == existing().createdAt && (isAdmin() || incoming().get('role', 'user') == existing().get('role', 'user'));
    }

    // --- Cached News ---
    function isValidNewsArticle(data) {
      return data.keys().hasAll(['id', 'title', 'url', 'createdAt']) &&
             data.id is string && data.id.size() <= 256 &&
             data.title is string && data.title.size() <= 512 &&
             data.url is string && data.url.size() <= 1024 &&
             data.createdAt is number &&
             data.get('description', '') is string && data.get('description', '').size() <= 5000 &&
             data.get('content', '') is string && data.get('content', '').size() <= 100000 &&
             data.get('imageUrl', '') is string && data.get('imageUrl', '').size() <= 1024 &&
             data.get('source', '') is string && data.get('source', '').size() <= 128 &&
             data.get('category', '') is string && data.get('category', '').size() <= 64 &&
             data.get('publishedAt', 0) is number &&
             data.get('region', '') is string && data.get('region', '').size() <= 64 &&
             data.get('views', 0) is number &&
             data.get('shares', 0) is number &&
             data.get('trendingScore', 0) is number;
    }

    match /cachedNews/{articleId} {
      // Public can read list and doc
      allow read: if true;
      // Admin can create or update (or backend using Admin SDK will bypass this entirely)
      allow create: if isAdmin() && isValidNewsArticle(incoming());
      // For view increments, anyone can update views/shares if they affect only those keys.
      allow update: if (isAdmin() && isValidNewsArticle(incoming())) ||
                       (incoming().diff(existing()).affectedKeys().hasOnly(['views', 'shares', 'trendingScore']) &&
                        incoming().views is number && incoming().shares is number && incoming().trendingScore is number);
      allow delete: if isAdmin();
    }

    // --- Bookmarks ---
    function isValidBookmark(data) {
      return data.keys().hasAll(['uid', 'articleId', 'createdAt']) && data.keys().size() <= 3 &&
             data.uid is string && data.uid == request.auth.uid &&
             data.articleId is string && data.articleId.size() <= 128 &&
             data.createdAt is number;
    }

    match /bookmarks/{bookmarkId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && isValidBookmark(incoming()) && incoming().createdAt == request.time.toMillis() && exists(/databases/$(database)/documents/cachedNews/$(incoming().articleId));
      allow delete: if isSignedIn() && existing().uid == request.auth.uid;
    }

    // --- Custom Posts ---
    function isValidCustomPost(data) {
      return data.keys().hasAll(['title', 'slug', 'content', 'createdAt', 'updatedAt', 'authorUid']) &&
             data.title is string && data.title.size() <= 256 &&
             data.slug is string && data.slug.size() <= 256 &&
             data.content is string && data.content.size() <= 100000 &&
             data.createdAt is number && data.updatedAt is number &&
             data.authorUid is string && data.authorUid == request.auth.uid &&
             data.get('coverImage', '') is string && data.get('coverImage', '').size() <= 1024 &&
             data.get('tags', []) is list && data.get('tags', []).size() <= 20 &&
             data.get('published', false) is bool &&
             data.get('views', 0) is number;
    }

    match /customPosts/{postId} {
      allow read: if existing().get('published', false) == true || isAdmin();
      allow create: if isAdmin() && isValidCustomPost(incoming()) && incoming().createdAt == request.time.toMillis() && incoming().updatedAt == request.time.toMillis();
      allow update: if isAdmin() && isValidCustomPost(incoming()) && incoming().createdAt == existing().createdAt && incoming().updatedAt == request.time.toMillis();
      allow delete: if isAdmin();
    }

    // --- Site Settings ---
    function isValidSettings(data) {
      return data.keys().hasAll(['updatedAt']) &&
             data.updatedAt is number &&
             data.get('breakingHeadline', '') is string && data.get('breakingHeadline', '').size() <= 256 &&
             data.get('featuredArticleId', '') is string && data.get('featuredArticleId', '').size() <= 128 &&
             data.get('pinnedArticles', []) is list && data.get('pinnedArticles', []).size() <= 10;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && settingId == 'global' && isValidSettings(incoming()) && incoming().updatedAt == request.time.toMillis();
    }
  }
}
